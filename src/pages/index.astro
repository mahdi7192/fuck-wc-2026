---
import '../styles/global.css';
import AppShell from '../components/AppShell.jsx';
---

<html lang="fa" dir="rtl">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>استادیوم بنجل‌ها | هو کردن بازیکنان ضعیف جام جهانی ۲۰۲۶</title>
		<meta name="description" content="در جریان بازی‌های زنده جام جهانی بازیکنان و تیم‌های بنجل را هو کنید و بنجل‌ترین‌های مسابقات را انتخاب کنید." />
		<meta name="robots" content="index, follow" />
		
		<!-- Telegram WebApp SDK -->
		<script src="https://telegram.org/js/telegram-web-app.js" defer></script>
	</head>
	<body>
		<main class="app-container" id="main-app-shell">
			<!-- AppShell Island React Component -->
			<AppShell client:only="react" />
		</main>

		<!-- Initialize Telegram WebApp Styling and Event Hooks -->
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				if (window.Telegram && window.Telegram.WebApp) {
					const webapp = window.Telegram.WebApp;
					
					// Expand the Web App to full height
					webapp.expand();
					
					// Inform Telegram the app is ready
					webapp.ready();

					// Disable vertical swipe-to-close gesture to prevent scroll freezing
					if (typeof webapp.disableVerticalSwipes === 'function') {
						webapp.disableVerticalSwipes();
					}
				}
			});
		</script>
	</body>
</html>
